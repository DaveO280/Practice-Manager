# Google one-click sign-in and Gmail send
# Get a client ID: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application), add your app origin (e.g. http://localhost:3000)
# Enable the Gmail API for the project
REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Venice AI for handwriting/schedule parsing (Import Schedule tab)
# Get an API key: https://venice.ai/ or https://docs.venice.ai/
# When "Use Venice AI for handwriting" is checked, schedule images are sent to Venice; fallback is Tesseract OCR
REACT_APP_VENICE_API_KEY=your-venice-api-key
# Optional: Venice model for vision/schedule parsing (must support images). Default: qwen-2.5-vl. See https://docs.venice.ai/ for available models.
REACT_APP_VENICE_MODEL=qwen-2.5-vl
